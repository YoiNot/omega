{
  "name": "omega",
  "version": "0.1.0",
  "private": true,
  "description": "PROJECT OMEGA — an autonomous, architecturally-sound browser game engine and simulation. Monorepo.",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/*",
    "apps/*",
    "packages/render-pbr",
    "packages/render-ao",
    "packages/job",
    "packages/pool",
    "packages/reflect",
    "packages/net-delta"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc -b",
    "bench": "vitest bench --run",
    "lint": "tsc -b --noEmit"
  },
  "devDependencies": {
    "@types/node": "^20.12.7",
    "@vitest/coverage-v8": "^1.6.1",
    "typescript": "^5.4.5",
    "vitest": "^1.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
